<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:vm="using:LANCommander.Launcher.Avalonia.ViewModels"
            xmlns:svg="using:Avalonia.Svg.Skia"
            x:Class="LANCommander.Launcher.Avalonia.Views.LoginView"
            x:DataType="vm:LoginViewModel">

    <Grid>
        <!-- Background image (set from code-behind) -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" />

        <!-- Dark overlay for readability -->
        <Border Background="#AA000000" />

        <!-- Login panel -->
        <Border Padding="40" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="20" Width="400">
                <svg:Svg Path="/Assets/logo.svg"
                         Height="40"
                         HorizontalAlignment="Center" />

                <TextBlock Text="Sign In"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Opacity="0.9"
                           Foreground="White" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Opacity="0.7">
                    <TextBlock Text="Connected to:" Foreground="White" />
                    <TextBlock Text="{Binding ServerAddress}" FontWeight="SemiBold" Foreground="White" />
                    <Button Content="Change"
                            Command="{Binding ChangeServerCommand}"
                            Padding="4,0"
                            Classes="hyperlink" />
                </StackPanel>

                <StackPanel Spacing="8" Margin="0,20,0,0">
                    <TextBlock Text="Username" FontWeight="SemiBold" Foreground="White" />
                    <TextBox x:Name="UsernameTextBox"
                             Watermark="Enter your username"
                             Text="{Binding Username}"
                             IsEnabled="{Binding !IsLoading}">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Return" Command="{Binding LoginCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Password" FontWeight="SemiBold" Foreground="White" />
                    <TextBox Watermark="Enter your password"
                             PasswordChar="•"
                             Text="{Binding Password}"
                             IsEnabled="{Binding !IsLoading}">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Return" Command="{Binding LoginCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                </StackPanel>

                <Button Command="{Binding LoginCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Classes="accent"
                        Padding="12"
                        IsEnabled="{Binding !IsLoading}">
                    <Panel>
                        <TextBlock Text="Sign In" IsVisible="{Binding !IsLoading}" />
                        <TextBlock Text="Signing in..." IsVisible="{Binding IsLoading}" />
                    </Panel>
                </Button>

                <Border IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Padding="12"
                        Background="#44FF0000"
                        CornerRadius="4">
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Foreground="White" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
