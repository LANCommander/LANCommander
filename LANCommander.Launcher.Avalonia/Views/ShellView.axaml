<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LANCommander.Launcher.Avalonia.ViewModels"
             xmlns:views="using:LANCommander.Launcher.Avalonia.Views"
             xmlns:converters="using:LANCommander.Launcher.Avalonia.Converters"
             x:Class="LANCommander.Launcher.Avalonia.Views.ShellView"
             x:DataType="vm:ShellViewModel">

    <UserControl.Styles>
        <Style Selector="Button.active">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto">

        <!-- ── Main Content ──────────────────────────────────────────── -->
        <ContentControl Grid.Row="0" Content="{Binding ContentView}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:GamesListViewModel">
                    <views:GamesListView />
                </DataTemplate>
                <DataTemplate DataType="vm:LibraryViewModel">
                    <views:GamesListView />
                </DataTemplate>
                <DataTemplate DataType="vm:GameDetailViewModel">
                    <views:GameDetailView />
                </DataTemplate>
                <DataTemplate DataType="vm:SettingsViewModel">
                    <views:SettingsView />
                </DataTemplate>
                <DataTemplate DataType="vm:DownloadQueueViewModel">
                    <views:DownloadQueuePageView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>

        <!-- ── Footer ────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="Black"
                BorderBrush="#22FFFFFF"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*" Height="52">

                <!-- Left: Depot / Library toggle -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Margin="12,0">
                    <Button Command="{Binding ShowDepotCommand}"
                            Classes="Text"
                            IsVisible="{Binding !IsDepotActive}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource PhosphorStorefront}"
                                      Width="14" Height="14"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Depot" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowLibraryCommand}"
                            Classes="Text"
                            IsVisible="{Binding !IsLibraryActive}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource PhosphorBooks}"
                                      Width="14" Height="14"
                                      VerticalAlignment="Center" />
                            <TextBlock Text="Library" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Center: active download OR idle downloads button -->
                <Panel Grid.Column="1">

                    <!-- Active download progress -->
                    <Button Classes="Text"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Command="{Binding ShowDownloadQueueCommand}"
                            IsVisible="{Binding DownloadQueue.HasActiveDownload}">

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                            <!-- Queue icon -->
                            <Border Grid.Column="0" Grid.RowSpan="2"
                                    Width="32" Height="32"
                                    CornerRadius="4"
                                    Background="{DynamicResource SystemAccentColor}"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource PhosphorArrowCircleDown}"
                                          Width="16" Height="16"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>

                            <!-- Title + time remaining -->
                            <DockPanel Grid.Column="1" Grid.Row="0">
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding DownloadQueue.TimeRemainingText}"
                                           FontSize="11" Opacity="0.6"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           IsVisible="{Binding DownloadQueue.TimeRemainingText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <TextBlock Text="{Binding DownloadQueue.CurrentItem.Title}"
                                           FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                            </DockPanel>

                            <!-- Speed + progress bar row -->
                            <Grid Grid.Column="1" Grid.Row="1" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DownloadQueue.TransferSpeedText}"
                                           FontSize="11" Opacity="0.6"
                                           VerticalAlignment="Center" />
                                <ProgressBar Grid.Column="0" Grid.ColumnSpan="2"
                                             Value="{Binding DownloadQueue.CurrentProgress}"
                                             Minimum="0" Maximum="1"
                                             Height="3"
                                             Margin="0,2,0,0"
                                             VerticalAlignment="Bottom" />
                            </Grid>
                        </Grid>
                    </Button>

                    <!-- Idle: always-visible downloads button + optional offline badge -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8"
                                IsVisible="{Binding !DownloadQueue.HasActiveDownload}">

                        <Button Command="{Binding ShowDownloadQueueCommand}"
                                Classes="Text">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource PhosphorDownloadSimple}"
                                          Width="13" Height="13"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Downloads" FontSize="13" VerticalAlignment="Center" />
                                <Border Background="{DynamicResource SystemAccentColor}"
                                        CornerRadius="8"
                                        Padding="5,1"
                                        IsVisible="{Binding DownloadQueue.HasPendingItems}">
                                    <TextBlock Text="{Binding DownloadQueue.ActiveCount}"
                                               FontSize="11" Foreground="White" />
                                </Border>
                            </StackPanel>
                        </Button>

                        <Border IsVisible="{Binding IsOfflineMode}"
                                Padding="10,4"
                                CornerRadius="4"
                                Background="#4A2D00">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="⚠" Foreground="#FFA500" />
                                <TextBlock Text="Offline Mode" Foreground="#FFA500" FontSize="12" FontWeight="SemiBold" />
                                <Button Content="Go Online"
                                        Command="{Binding TryGoOnlineCommand}"
                                        Background="#0E639C"
                                        Foreground="White"
                                        Padding="8,2"
                                        FontSize="11"
                                        IsVisible="{Binding CanGoOnline}" />
                            </StackPanel>
                        </Border>

                    </StackPanel>

                </Panel>

            </Grid>
        </Border>

    </Grid>
</UserControl>
