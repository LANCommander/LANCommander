@page "/Pages/Edit"
@page "/Pages/Edit/{id:guid}"
@attribute [Authorize(Roles = RoleService.AdministratorRoleName)]
@using LANCommander.Server.UI.Pages.Pages.Components
@using PSC.Blazor.Components.MarkdownEditor
@using PSC.Blazor.Components.MarkdownEditor.Models
@inject MediaService MediaService
@inject PageService PageService
@inject ConfirmService ConfirmService
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject ILogger<Index> Logger

<Layout Class="panel-layout">
    <Content>
        <PageHeader>
            <PageHeaderTitle>Pages</PageHeaderTitle>
            <PageHeaderExtra>
                <Space>
                    @if (SelectedPage != null)
                    {
                        <SpaceItem>
                            <Button Type="ButtonType.Primary" OnClick="Save">Save</Button>
                        </SpaceItem>

                        <SpaceItem>
                            <Dropdown>
                                <Overlay>
                                    <Menu>
                                        <MenuItem OnClick="Delete">Delete</MenuItem>
                                        <MenuItem OnClick="AddNewPage">New Page</MenuItem>
                                    </Menu>
                                </Overlay>
                                
                                <ChildContent>
                                    <Button Type="ButtonType.Default" Icon="@IconType.Outline.Ellipsis" />
                                </ChildContent>
                            </Dropdown>
                        </SpaceItem>
                    }
                    else
                    {
                        <SpaceItem>
                            <Button Type="ButtonType.Primary" OnClick="AddNewPage">New Page</Button>
                        </SpaceItem>
                    }
                </Space>
            </PageHeaderExtra>
        </PageHeader>

        <SplitPane Class="page-editor-body">
            <Pane Size="25%" Class="page-editor-tree-pane">
                <Tree
                    @ref="Tree"
                      Draggable
                      BlockNode
                      ShowIcon
                      DefaultExpandAll="true"
                      TItem="Page"
                      DataSource="Pages"
                      ChildrenExpression="p => p.DataItem?.Children?.OrderBy(p => p.SortOrder)"
                      KeyExpression="p => p.DataItem?.Id.ToString()"
                      OnDrop="OnDrop"
                      OnSelect="SelectPage">
                    <TitleTemplate>
                        @{
                            // Shared menu so a right-click on the row and a click on the ellipsis
                            // button below open the exact same actions.
                            var node = context.DataItem;

                            RenderFragment contextMenu =
                                @<Menu>
                                    <MenuItem OnClick="() => AddSiblingPage(node)">New Page</MenuItem>
                                    <MenuItem OnClick="() => AddChildPage(node)">Add Child Page</MenuItem>
                                    <MenuItem OnClick="() => DeletePage(node)">Delete</MenuItem>
                                </Menu>;
                        }
                        <Dropdown Trigger="@(new Trigger[] { Trigger.ContextMenu })" Class="page-editor-tree-title">
                            <Overlay>@contextMenu</Overlay>
                            <ChildContent>
                                <Flex Align="FlexAlign.Center" Justify="FlexJustify.SpaceBetween">
                                    <span>@node?.Title</span>

                                    @* Nested click-triggered dropdown so the button opens the same menu;
                                       stopPropagation keeps the click from also selecting the tree node. *@
                                    <span class="page-editor-tree-action" @onclick:stopPropagation="true">
                                        <Dropdown Trigger="@(new Trigger[] { Trigger.Click })">
                                            <Overlay>@contextMenu</Overlay>
                                            <ChildContent>
                                                <Button Type="ButtonType.Text" Icon="@IconType.Outline.Ellipsis" />
                                            </ChildContent>
                                        </Dropdown>
                                    </span>
                                </Flex>
                            </ChildContent>
                        </Dropdown>
                    </TitleTemplate>
                </Tree>
            </Pane>

            <Pane Size="75%" Class="page-editor-markdown-pane">
                @if (SelectedPage != null)
                {
                    <Form @ref="Form" Model="SelectedPage">
                        <FormItem Style="margin-bottom: 8px" Rules="@(new[] { new FormValidationRule { Required = true, Message = "Title is required" } })">
                            <Input @bind-Value="context.Title" @bind-Value:after="SyncSlugFromTitle" Size="InputSize.Large" Placeholder="Page Title" AutoFocus />
                        </FormItem>

                        <FormItem Label="Slug" Style="margin-bottom: 8px; padding-left: 8px">
                            <SlugEditorInput @bind-Page="context" />
                        </FormItem>

                        @if (SelectedPage.Children == null || !SelectedPage.Children.Any())
                        {
                            <FormItem Style="margin-bottom: 8px">
                                <FormItem Class="ant-typography">
                                    <MarkdownEditor
                                        @ref="MarkdownEditor"
                                        @bind-Value="context.Contents"
                                        UploadImage="true"
                                        ImageUploadEndpoint="/api/Media/Upload/PageImage"
                                        CustomImageUpload="UploadImage"
                                        SpellChecker="false"
                                        CSSClass="ant-typography"
                                        MinHeight="500px" />
                                </FormItem>
                            </FormItem>
                        }
                    </Form>
                }
                else
                {
                    <Empty>
                        <DescriptionTemplate>
                            No page is selected
                        </DescriptionTemplate>
                        <ChildContent>
                            <Button Type="@ButtonType.Primary" OnClick="AddNewPage">New Page</Button>
                        </ChildContent>
                    </Empty>
                }
            </Pane>
        </SplitPane>
    </Content>
</Layout>

@code {
    [Parameter] public Guid Id { get; set; }

    string NewPageTitle { get; set; }

    Tree<Page> Tree { get; set; }
    Form<Page> Form { get; set; }
    Page SelectedPage { get; set; }
    MarkdownEditor MarkdownEditor { get; set; }
    ICollection<Page> Pages { get; set; } = new List<Page>();

    string OriginalContent { get; set; }
    string OriginalTitle { get; set; }

    // Tracks the title the current slug was derived from, so the slug keeps following
    // the title until the user manually customizes it.
    string LastTitle { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id != Guid.Empty)
        {
            // Include the parent so RenderRoute produces the correct nested route on save
            // (the parent's stored Route holds the full ancestor path).
            SelectedPage = await PageService.Include(p => p.Parent).FirstOrDefaultAsync(p => p.Id == Id);

            if (SelectedPage == null)
                NavigationManager.NavigateTo("/Pages/Edit");

            OriginalContent = SelectedPage.Contents;
            OriginalTitle = SelectedPage.Title;
            LastTitle = SelectedPage.Title;

            await InvokeAsync(StateHasChanged);
        }
    }

    void SyncSlugFromTitle()
    {
        var autoSlug = LastTitle.ToRouteSlug();

        if (String.IsNullOrEmpty(SelectedPage.Slug) || SelectedPage.Slug == autoSlug)
        {
            SelectedPage.Slug = SelectedPage.Title.ToRouteSlug();
            SelectedPage.Route = PageService.RenderRoute(SelectedPage);
        }

        LastTitle = SelectedPage.Title;
    }

    async Task LoadData()
    {
        var allPages = await PageService.SortBy(p => p.SortOrder).GetAsync();
        var childrenByParent = allPages.ToLookup(p => p.ParentId);

        foreach (var page in allPages)
        {
            page.Children = childrenByParent[page.Id].ToList();

            foreach (var child in page.Children)
                child.Parent = page;
        }

        Pages = childrenByParent[null].ToList();

        await InvokeAsync(StateHasChanged);
    }

    async Task OnDrop(TreeEventArgs<Page> e)
    {
        List<Guid> childOrder = new List<Guid>();
        
        // DropBelow is true if a tree node is supposed to be placed beneath a sibling
        if (e.DropBelow)
        {
            var parentId = e.TargetNode.DataItem.Parent?.Id ?? Guid.Empty;
            var parentNode = Tree.GetNode(parentId.ToString());
            var sibling = e.TargetNode;

            if (parentId == Guid.Empty)
                childOrder = (await PageService.GetAsync(p => p.Parent == null)).Select(p => p.Id).ToList();
            else
                childOrder = parentNode.DataItem.Children.Select(c => c.Id).ToList();

            childOrder.Remove(e.Node.DataItem.Id);

            var targetPosition = childOrder.FindIndex(c => c == e.TargetNode.DataItem.Id);

            childOrder.Insert(targetPosition + 1, e.Node.DataItem.Id);

            await PageService.UpdateOrderAsync(parentId, childOrder);
        }
        else
        {
            childOrder = e.TargetNode.DataItem.Children.Select(c => c.Id).ToList();

            childOrder.Remove(e.Node.DataItem.Id);
            childOrder.Insert(0, e.Node.DataItem.Id);

            await PageService.UpdateOrderAsync(e.TargetNode.DataItem.Id, childOrder);
        }

        await LoadData();
    }

    async Task AddNewPage()
    {
        Guid? parentId = null;

        if (SelectedPage != null)
            parentId = SelectedPage.ParentId != null && SelectedPage.ParentId != Guid.Empty
                ? SelectedPage.ParentId
                : SelectedPage.Id;

        await CreatePageAsync(parentId);
    }

    // Context-menu action: create a page at the same level as the clicked page (its sibling).
    async Task AddSiblingPage(Page page) => await CreatePageAsync(page?.ParentId);

    // Context-menu action: create a child beneath the clicked page.
    async Task AddChildPage(Page page) => await CreatePageAsync(page?.Id);

    async Task CreatePageAsync(Guid? parentId)
    {
        try
        {
            var newPage = await PageService.AddAsync(new Page
            {
                Title = "New Page",
                Slug = "new-page",
                Contents = "",
            });

            if (parentId is Guid pid && pid != Guid.Empty)
                await PageService.ChangeParentAsync(newPage.Id, pid);

            await LoadData();

            NavigationManager.NavigateTo($"/Pages/Edit/{newPage.Id}");
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "An error occurred while trying to add a new page");
            MessageService.Error("Error adding new page!");
        }
    }

    Task Delete() => DeletePage(SelectedPage);

    async Task DeletePage(Page page)
    {
        try
        {
            if (page == null)
                return;

            var parentId = page.ParentId ?? Guid.Empty;

            var entity = await PageService.GetAsync(page.Id);

            await PageService.DeleteAsync(entity);

            MessageService.Success("Page deleted!");

            await LoadData();

            // Only navigate away if the deleted page was the one being edited.
            if (SelectedPage?.Id == page.Id)
            {
                if (parentId != Guid.Empty)
                    NavigationManager.NavigateTo($"/Pages/Edit/{parentId}");
                else
                    NavigationManager.NavigateTo($"/Pages/Edit");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting page!");
            MessageService.Error("Error deleting page!");
        }
    }

    async Task Save()
    {
        try
        {
            if (Form != null && !Form.Validate())
                return;

            await PageService.UpdateAsync(SelectedPage);
            MessageService.Success("Page updated!");

            // Reset the change-tracking baseline so navigating away doesn't falsely
            // prompt about unsaved changes.
            OriginalContent = SelectedPage.Contents;
            OriginalTitle = SelectedPage.Title;
            LastTitle = SelectedPage.Title;

            await LoadData();
        }
        catch (Exception ex)
        {
            MessageService.Error("Could not save page!");
            Logger.LogError(ex, "Could not save page!");
        }
    }

    async Task SelectPage(TreeEventArgs<Page> e)
    {
        var modified = SelectedPage?.Contents != OriginalContent || SelectedPage?.Title != OriginalTitle;

        if (Form != null && modified)
        {
            var confirmResult = await ConfirmNavigate();

            if (confirmResult == ConfirmResult.Yes)
            {
                // Save
                await Save();

                NavigationManager.NavigateTo($"/Pages/Edit/{e.Node.DataItem.Id}");
            }
            else if (confirmResult == ConfirmResult.No)
            {
                // Discard
                await LoadData();

                NavigationManager.NavigateTo($"/Pages/Edit/{e.Node.DataItem.Id}");
            }
            else return;
        }

        NavigationManager.NavigateTo($"/Pages/Edit/{e.Node.DataItem.Id}");
    }

    async Task<ConfirmResult> ConfirmNavigate()
    {
        var confirmResult = await ConfirmService.Show(
            "You are about to discard your unsaved changes.",
            "Unsaved Changes",
            ConfirmButtons.YesNoCancel,
            ConfirmIcon.Warning,
            new ConfirmButtonOptions
                {
                    Button1Props = new ButtonProps
                    {
                        Type = ButtonType.Primary,
                        ChildContent = "Save",
                    },
                    Button2Props = new ButtonProps
                    {
                        Type = ButtonType.Default,
                        ChildContent = "Discard",
                        Danger = false,
                    },
                    Button3Props = new ButtonProps
                    {
                        Type = ButtonType.Text,
                        ChildContent = "Cancel",
                    }
                }
        );

        return confirmResult;
    }

    async Task<FileEntry> UploadImage(MarkdownEditor editor, FileEntry entry)
    {
        var stream = new MemoryStream(Convert.FromBase64String(entry.ContentBase64));

        var media = new Media()
        {
            Type = SDK.Enums.MediaType.PageImage,
            MimeType = entry.Type,
            Crc32 = ""
        };
        
        media = await MediaService.AddAsync(media);
        media = await MediaService.WriteToFileAsync(media, stream);
        media = await MediaService.UpdateAsync(media);

        entry.UploadUrl = $"/api/Media/{media.Id}/Download?fileId={media.FileId}";

        return entry;
    }
}
