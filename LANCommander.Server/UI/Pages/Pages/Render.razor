@page "/Pages/{*route}"
@using LANCommander.SDK.Extensions
@using LANCommander.Server.UI.Pages.Pages.Components
@using LANCommander.UI
@using Markdig
@using ZiggyCreatures.Caching.Fusion
@using LANCommander.Server.Services.Abstractions
@inject PageService PageService
@inject IFusionCache Cache
@inject NavigationManager NavigationManager
@inject IVersionProvider VersionProvider

@if (Page != null)
{
    <Layout Class="panel-layout">
        <Content>
            <SplitPane Style="flex-grow: 1">
                <Pane Size="25%" Class="page-nav">
                    <PageMenu CurrentRoute="@Page.Route" />
                </Pane>

                <Pane Size="75%">
                    @if (Ancestors.Any())
                    {
                        <div style="padding: 16px 24px 0;">
                            <Breadcrumb>
                                @foreach (var ancestor in Ancestors)
                                {
                                    <BreadcrumbItem Href="@($"/{ancestor.Route}")">@ancestor.Title</BreadcrumbItem>
                                }
                                <BreadcrumbItem>@Page.Title</BreadcrumbItem>
                            </Breadcrumb>
                        </div>
                    }

                    <PageHeader Title="@Page.Title" />

                    <div style="padding: 0 24px;">
                        @((MarkupString)Markdig.Markdown.ToHtml(Page.Contents ?? "", PagePipeline))
                    </div>
                </Pane>
            </SplitPane>
        </Content>
    </Layout>
}
else if (NotFoundResult)
{
    <Layout Class="panel-layout">
        <Content>
            <NotFound Title="Page Not Found">
                <Extra>
                    <a href="/Pages"><Button Type="@ButtonType.Primary">Back to Pages</Button></a>
                </Extra>
            </NotFound>
        </Content>
    </Layout>
}

<link rel="stylesheet" href="~/css/pages.css?v=@(VersionProvider.GetCurrentVersion())" />

@code {
    // Markdown from page contents is rendered as raw markup, so raw HTML is stripped
    // to prevent stored XSS from executing for public visitors.
    static readonly MarkdownPipeline PagePipeline = new MarkdownPipelineBuilder()
        .DisableHtml()
        .UseAdvancedExtensions()
        .Build();

    [Parameter] public string Route { get; set; }

    Page Page;
    bool NotFoundResult;
    List<Page> Ancestors = new();

    protected override async Task OnParametersSetAsync()
    {
        Page = null;
        NotFoundResult = false;
        Ancestors = new();

        if (Route == null)
        {
            var firstParent = await PageService.Query(q =>
            {
                return q.OrderBy(p => p.SortOrder);
            }).FirstOrDefaultAsync(p => p.Parent == null);

            if (firstParent == null)
                NavigationManager.NavigateTo("/");
            else
                NavigationManager.NavigateTo($"/{firstParent.Route}");
        }
        else
        {
            var route = Route.TrimEnd('/');

            Page = await Cache.GetOrSetAsync<Page>(PageService.GetCacheKey(route), async _ =>
            {
                // Routes are stored in PascalCase; match case-insensitively so the incoming
                // URL casing doesn't have to be exact.
                var target = $"Pages/{route}".ToLower();

                return await PageService.FirstOrDefaultAsync(p => p.Route.ToLower() == target);
            });

            if (Page == null)
                NotFoundResult = true;
            else
                await LoadAncestorsAsync();
        }
    }

    async Task LoadAncestorsAsync()
    {
        var chain = new List<Page>();
        var parentId = Page.ParentId;

        while (parentId != null && parentId != Guid.Empty)
        {
            var ancestor = await PageService.GetAsync(parentId.Value);

            if (ancestor == null)
                break;

            chain.Insert(0, ancestor);
            parentId = ancestor.ParentId;
        }

        Ancestors = chain;
    }
}
